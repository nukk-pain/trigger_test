# Pain Guide Helper MVP runtime environment
#
# Copy this file to .env.local for local development.
# Never put real secrets in this example file.

# Server-only secrets
OPENROUTER_API_KEY=<your-openrouter-api-key>
UPSTASH_REDIS_REST_URL=<your-upstash-redis-rest-url>
UPSTASH_REDIS_REST_TOKEN=<your-upstash-redis-rest-token>

# OpenRouter request settings
# Select an explicit low-cost production model before deployment.
OPENROUTER_MODEL=<choose-openrouter-model>
MAX_TOKENS=800
TEMPERATURE=1
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Pain Guide Helper

# Request and cost controls
DAILY_REQUEST_LIMIT=20
MONTHLY_REQUEST_LIMIT=200
SERVER_RATE_LIMIT_MAX=20
SERVER_RATE_LIMIT_WINDOW_SECONDS=86400
MAX_CHAT_MESSAGES=6
MAX_CHAT_MESSAGE_CHARS=2000
MAX_CHAT_BODY_BYTES=16384

# Feature flags
ENABLE_AI_QA=false
ENABLE_DETAILED_ANALYSIS=true

# Browser/API origin policy
ALLOWED_ORIGINS=http://localhost:3000

# Rate-limit store
# Local/test may use memory. Production must use upstash with durable env vars.
RATE_LIMIT_STORE=memory|upstash
REQUIRE_DURABLE_RATE_LIMIT=true
